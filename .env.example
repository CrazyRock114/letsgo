# ===========================================
# 小围棋乐园 - 环境变量配置
# ===========================================
# 复制此文件为 .env.local 并填入实际值
# Railway部署时在 Variables 页面配置

# ---- Supabase 数据库（必填） ----
COZE_SUPABASE_URL=https://your-project.supabase.co
COZE_SUPABASE_ANON_KEY=your-anon-key
COZE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- LLM 提供者（二选一，优先 Coze） ----
# 方案1: Coze SDK（Coze 沙箱自动注入，Railway 需手动设置）
# COZE_WORKLOAD_IDENTITY_API_KEY=your-coze-api-key
# COZE_INTEGRATION_BASE_URL=https://api.coze.com
# COZE_INTEGRATION_MODEL_BASE_URL=https://model.coze.com

# 方案2: DeepSeek API（Railway 推荐）
DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_API_BASE_URL=https://api.deepseek.com   # 默认值，可覆盖
# DEEPSEEK_MODEL=deepseek-chat                       # 默认值，可覆盖

# ---- 环境标识（可选） ----
COZE_PROJECT_ENV=PROD
