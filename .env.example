# ===========================================
# 小围棋乐园 - 环境变量配置
# ===========================================
# 复制此文件为 .env.local 并填入实际值
# Railway部署时在 Variables 页面配置

# ---- Supabase 数据库（必填） ----
# 优先使用 SUPABASE_* 变量（自建Supabase），兼容 COZE_SUPABASE_* 变量（Coze内置）
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 数据库直连URL（用于docker-start.sh自动迁移，可选）
# 格式: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# SUPABASE_DB_URL=postgresql://postgres.project-ref:password@aws-0-region.pooler.supabase.com:6543/postgres

# ---- LLM 提供者（二选一，优先 Coze） ----
# 方案1: Coze SDK（Coze 沙箱自动注入，Railway 需手动设置）
# COZE_WORKLOAD_IDENTITY_API_KEY=your-coze-api-key
# COZE_INTEGRATION_BASE_URL=https://api.coze.com
# COZE_INTEGRATION_MODEL_BASE_URL=https://model.coze.com

# 方案2: DeepSeek API（Railway 推荐）
DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_API_BASE_URL=https://api.deepseek.com   # 默认值，可覆盖
# DEEPSEEK_MODEL=deepseek-chat                       # 默认值，可覆盖

# ---- 环境标识（可选） ----
COZE_PROJECT_ENV=PROD
